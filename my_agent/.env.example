TELEGRAM_TOKEN=replace-with-your-telegram-bot-token

# Main reasoning/synthesis model. Examples:
# LLM_MODEL=gemini-3.5-flash
# LLM_MODEL=openai/gpt-4.1
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_MODEL=groq/llama-3.3-70b-versatile
# LLM_MODEL=ollama/llama3.1
LLM_MODEL=gemini-3.5-flash
# Optional comma-separated fallback reasoning models used on quota, demand,
# overload, timeout, 429, or 503-style provider failures.
LLM_MODEL_FALLBACKS=openai/gpt-4.1,anthropic/claude-sonnet-4-5,groq/llama-3.3-70b-versatile

# Keep this Gemini when using ADK's built-in google_search tool.
SEARCH_MODEL=gemini-3.5-flash
# Optional comma-separated Gemini fallbacks for the web-search agent.
SEARCH_MODEL_FALLBACKS=gemini-3.5-flash-lite

# Add only the key for the provider you use.
GOOGLE_API_KEY=replace-with-your-google-api-key
OPENAI_API_KEY=replace-with-your-openai-api-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
GROQ_API_KEY=replace-with-your-groq-api-key
MISTRAL_API_KEY=replace-with-your-mistral-api-key
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
